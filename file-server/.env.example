# MIS File Server Environment Variables
# Copy this to .env and update with your actual values

# File Server Location: /home/scorpio/calibur/mis-dept-website/linux-server/file-server
# Running from: /opt/misapp-file-server (via symlink or copy from setup.sh)

# Node environment
NODE_ENV=production

# Server port (usually 3001, behind Nginx reverse proxy)
PORT=3001

# Upload directory (created by setup script)
UPLOAD_DIR=/var/www/misapp/uploads

# Log directory (created by setup script)
LOG_DIR=/var/log/misapp

# API key for authentication (optional, for admin endpoints)
# Generate a strong password: openssl rand -base64 32
API_KEY=your-secret-api-key-here-change-this

# Allowed origins for CORS
# Add your Vercel domain and file server domain
# Format: https://domain1.com,https://domain2.com
ALLOWED_ORIGINS=https://your-app.vercel.app,https://files.your-domain.com
